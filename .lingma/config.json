{
  "$schema": "https://lingma.ai/schema/config.json",
  "version": "1.0.0",
  "project": {
    "name": "Tourbook",
    "type": "travel-memoir",
    "privacy": "private",
    "language": {
      "primary": "en",
      "secondary": "zh-CN",
      "explanations": "zh-CN"
    }
  },
  "skills": {
    "enabled": [
      "autobiography-editor",
      "timeline-context"
    ],
    "default": "tourbook-assistant"
  },
  "agents": {
    "enabled": [
      "tourbook-assistant"
    ]
  },
  "rules": {
    "enabled": [
      "file-access",
      "code-style",
      "writing-style",
      "privacy-protection"
    ]
  },
  "filePatterns": {
    "include": [
      "**/*.md",
      "**/*.mdx",
      "**/*.json",
      "**/*.js"
    ],
    "exclude": [
      "docs/assets/confidential/*.md",
      "node_modules/**",
      ".git/**"
    ],
    "requirePermission": [
      "docs/assets/confidential/*.mdx"
    ]
  },
  "customComponents": {
    "prefix": "a-",
    "types": [
      "flight",
      "map",
      "img",
      "hotel",
      "times",
      "secret",
      "bg"
    ]
  },
  "permissionRules": {
    "confidentialMdx": {
      "pattern": "docs/assets/confidential/*.mdx",
      "rule": "must-ask-before-access",
      "message": "This is confidential content. Do you want me to access this file?",
      "exceptions": []
    }
  }
}
